#!/usr/bin/env python3
"""
EdgeOS Object Detection Demo
USB webcam -> YOLOv8n inference (onnxruntime) -> live terminal output

Pure onnxruntime + OpenCV implementation. Does NOT import ultralytics or torch
so it runs on a minimal inference-only image.

By default the script runs YOLO inference on the i.MX8MP NPU (VSI NPU
execution provider). Pass --cpu to force CPU.

Usage:
  edgeos-detect                  # default camera /dev/video0, NPU backend
  edgeos-detect --cpu            # force CPU inference
  edgeos-detect --camera 1       # use /dev/video1
  edgeos-detect --conf 0.3       # lower confidence threshold
  edgeos-detect --width 320 --height 240   # lower capture resolution
  edgeos-detect --list-cameras   # show available video devices
"""

import os, sys, time, argparse

MODEL_DIR  = "/var/lib/edgeos-demo"
MODEL_FILE = os.path.join(MODEL_DIR, "yolov8n.onnx")

# YOLOv8 input geometry (matches the official yolov8n.onnx export at imgsz=640).
INPUT_SIZE = 640
IOU_THRESH = 0.45

# COCO 80-class label set used by stock yolov8n.
COCO_NAMES = [
    "person", "bicycle", "car", "motorcycle", "airplane", "bus", "train",
    "truck", "boat", "traffic light", "fire hydrant", "stop sign",
    "parking meter", "bench", "bird", "cat", "dog", "horse", "sheep", "cow",
    "elephant", "bear", "zebra", "giraffe", "backpack", "umbrella", "handbag",
    "tie", "suitcase", "frisbee", "skis", "snowboard", "sports ball", "kite",
    "baseball bat", "baseball glove", "skateboard", "surfboard",
    "tennis racket", "bottle", "wine glass", "cup", "fork", "knife", "spoon",
    "bowl", "banana", "apple", "sandwich", "orange", "broccoli", "carrot",
    "hot dog", "pizza", "donut", "cake", "chair", "couch", "potted plant",
    "bed", "dining table", "toilet", "tv", "laptop", "mouse", "remote",
    "keyboard", "cell phone", "microwave", "oven", "toaster", "sink",
    "refrigerator", "book", "clock", "vase", "scissors", "teddy bear",
    "hair drier", "toothbrush",
]


def parse_args():
    p = argparse.ArgumentParser(description="EdgeOS USB webcam object detection")
    p.add_argument("--camera",       type=int,   default=0,    help="Camera index (default: 0)")
    p.add_argument("--conf",         type=float, default=0.40, help="Confidence threshold 0-1 (default: 0.40)")
    p.add_argument("--width",        type=int,   default=640,  help="Capture width (default: 640)")
    p.add_argument("--height",       type=int,   default=480,  help="Capture height (default: 480)")
    p.add_argument("--list-cameras", action="store_true",      help="List available video devices and exit")
    p.add_argument("--cpu",          action="store_true",      help="Force CPU inference (default: NPU)")
    return p.parse_args()


def list_cameras():
    import glob
    devices = sorted(glob.glob("/dev/video*"))
    if not devices:
        print("No video devices found.")
        return
    print("Available video devices:")
    for d in devices:
        print(f"  {d}")


def ensure_model():
    """The model is shipped inside the edgeos-demo package and lives at
    /var/lib/edgeos-demo/yolov8n.onnx on a stock rootfs. No download needed.
    If the file is missing the package is broken; tell the user how to restore."""
    if os.path.exists(MODEL_FILE):
        return MODEL_FILE

    sys.exit(
        f"ERROR: YOLO model missing at {MODEL_FILE}\n"
        f"  The model is shipped with the edgeos-demo package and is normally\n"
        f"  pre-installed by the image. Restore it with:\n"
        f"      opkg install --force-reinstall edgeos-demo\n"
        f"  Or copy a fresh yolov8n.onnx into {MODEL_DIR}/ manually."
    )


def letterbox(img, new_size=INPUT_SIZE, pad_value=114):
    """Resize to new_size x new_size preserving aspect ratio; pad with pad_value."""
    import cv2, numpy as np
    h, w = img.shape[:2]
    scale = min(new_size / h, new_size / w)
    nh, nw = int(round(h * scale)), int(round(w * scale))
    resized = cv2.resize(img, (nw, nh), interpolation=cv2.INTER_LINEAR)
    canvas = np.full((new_size, new_size, 3), pad_value, dtype=np.uint8)
    top  = (new_size - nh) // 2
    left = (new_size - nw) // 2
    canvas[top:top + nh, left:left + nw] = resized
    return canvas, scale, left, top


def nms(boxes, scores, iou_thresh):
    """Pure-numpy NMS. boxes are (x1, y1, x2, y2)."""
    import numpy as np
    if len(boxes) == 0:
        return []
    x1, y1, x2, y2 = boxes[:, 0], boxes[:, 1], boxes[:, 2], boxes[:, 3]
    areas = (x2 - x1).clip(min=0) * (y2 - y1).clip(min=0)
    order = scores.argsort()[::-1]
    keep = []
    while order.size > 0:
        i = order[0]
        keep.append(i)
        if order.size == 1:
            break
        xx1 = np.maximum(x1[i], x1[order[1:]])
        yy1 = np.maximum(y1[i], y1[order[1:]])
        xx2 = np.minimum(x2[i], x2[order[1:]])
        yy2 = np.minimum(y2[i], y2[order[1:]])
        inter = (xx2 - xx1).clip(min=0) * (yy2 - yy1).clip(min=0)
        iou = inter / (areas[i] + areas[order[1:]] - inter + 1e-9)
        order = order[1:][iou <= iou_thresh]
    return keep


def postprocess(output, conf_thresh):
    """
    YOLOv8 ONNX raw output: shape (1, 84, 8400). 4 box coords + 80 class scores
    per prediction, no separate objectness. Returns a list of (class_id, score).
    """
    import numpy as np
    preds = output[0].T                  # -> (8400, 84)
    class_scores = preds[:, 4:]          # (8400, 80)
    class_ids = class_scores.argmax(axis=1)
    scores = class_scores.max(axis=1)

    mask = scores >= conf_thresh
    if not mask.any():
        return []

    boxes_cxcywh = preds[mask, :4]
    scores = scores[mask]
    class_ids = class_ids[mask]

    cx, cy, w, h = boxes_cxcywh.T
    x1 = cx - w / 2
    y1 = cy - h / 2
    x2 = cx + w / 2
    y2 = cy + h / 2
    boxes = np.stack([x1, y1, x2, y2], axis=1)

    keep = nms(boxes, scores, IOU_THRESH)
    return [(int(class_ids[i]), float(scores[i])) for i in keep]


def clear_screen():
    print("\033[2J\033[H", end="", flush=True)


def pick_providers(ort, force_cpu):
    """Prefer the NXP VSI NPU execution provider; fall back to CPU."""
    available = ort.get_available_providers()
    if force_cpu:
        return ["CPUExecutionProvider"], "CPU (forced via --cpu)"

    # NXP eIQ ships the VSI NPU EP as "VsiNpuExecutionProvider" in their
    # onnxruntime build for i.MX8MP. Newer builds may expose it under a
    # different short name; accept either spelling.
    for npu_name in ("VsiNpuExecutionProvider", "VSINPUExecutionProvider"):
        if npu_name in available:
            return [npu_name, "CPUExecutionProvider"], f"NPU ({npu_name})"

    return ["CPUExecutionProvider"], (
        "CPU (NPU provider not in this onnxruntime build. "
        "Available: " + ", ".join(available) + ")"
    )


def run(args):
    try:
        import cv2
        import numpy as np
    except ImportError as e:
        sys.exit(f"ERROR: required Python module missing ({e}). "
                 f"Expected python3-opencv and python3-numpy on the rootfs.")
    try:
        import onnxruntime as ort
    except ImportError as e:
        sys.exit(f"ERROR: onnxruntime not found ({e}). "
                 f"Expected the onnxruntime package on the rootfs.")

    model_path = ensure_model()
    providers, backend_label = pick_providers(ort, args.cpu)
    print(f"Loading model: {model_path}")
    print(f"Inference backend: {backend_label}")
    sess = ort.InferenceSession(model_path, providers=providers)
    input_name = sess.get_inputs()[0].name
    # Record which provider actually got selected (NPU may silently fall back
    # for unsupported ops; ORT reports the active list per-node via the session).
    active = sess.get_providers()
    if active and active[0] != providers[0]:
        print(f"NOTE: onnxruntime selected {active[0]} instead of requested {providers[0]}.")
    backend_short = "NPU" if active and active[0].lower().startswith("vsi") else "CPU"

    print(f"Opening /dev/video{args.camera} at {args.width}x{args.height} ...")
    cap = cv2.VideoCapture(args.camera)
    if not cap.isOpened():
        sys.exit(f"ERROR: Cannot open /dev/video{args.camera}\n"
                 f"  Check the device exists: ls /dev/video*\n"
                 f"  Try a different index:    edgeos-detect --camera 1")

    cap.set(cv2.CAP_PROP_FRAME_WIDTH,  args.width)
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, args.height)

    actual_w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    actual_h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    print(f"Camera ready: {actual_w}x{actual_h}  |  Press Ctrl+C to stop\n")
    time.sleep(0.5)

    frame_n = 0
    fps_avg = 0.0
    t_start = time.time()

    try:
        while True:
            ret, frame = cap.read()
            if not ret:
                print("ERROR: Lost camera feed.")
                break

            t0 = time.perf_counter()

            img, _scale, _left, _top = letterbox(frame, INPUT_SIZE)
            rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
            blob = (rgb.astype(np.float32) / 255.0).transpose(2, 0, 1)[None]

            outputs = sess.run(None, {input_name: blob})
            detections = postprocess(outputs[0], args.conf)

            elapsed = time.perf_counter() - t0
            detections.sort(key=lambda x: x[1], reverse=True)

            frame_n += 1
            fps_inst = 1.0 / elapsed if elapsed > 0 else 0.0
            fps_avg  = fps_avg * 0.85 + fps_inst * 0.15
            runtime  = time.time() - t_start

            clear_screen()
            W = 54
            print("┌" + "─" * W + "┐")
            print(f"│  EdgeOS object detection demo{' ' * (W - 30)}│")
            print("├" + "─" * W + "┤")
            print(f"│  Camera : /dev/video{args.camera:<3}  Resolution: {actual_w}x{actual_h:<8}│")
            print(f"│  Frame  : {frame_n:<6}       Runtime:  {runtime:>6.0f}s          │")
            print(f"│  Latency: {elapsed*1000:>5.1f} ms     FPS (avg): {fps_avg:>5.1f}           │")
            print(f"│  Conf.  : >{args.conf:.0%}   Backend: {backend_short:<3}   Model: YOLOv8n  │")
            print("├" + "─" * W + "┤")
            print(f"│  {'Object':<22} {'Confidence':>12}  {'Bar':<14}  │")
            print("├" + "─" * W + "┤")

            if not detections:
                print(f"│  {'(nothing detected above threshold)':<{W - 2}}│")
            else:
                for cls_id, conf in detections[:8]:
                    label  = COCO_NAMES[cls_id] if 0 <= cls_id < len(COCO_NAMES) else f"cls{cls_id}"
                    filled = int(conf * 14)
                    bar    = "█" * filled + "░" * (14 - filled)
                    print(f"│  {label:<22} {conf:>11.1%}  {bar}  │")

            print("└" + "─" * W + "┘")
            print("  Ctrl+C to stop  |  --conf to adjust threshold  |  --camera N for other device")

    except KeyboardInterrupt:
        print("\n\nStopped. Total frames processed:", frame_n)
    finally:
        cap.release()


def main():
    args = parse_args()
    if args.list_cameras:
        list_cameras()
        return
    run(args)


if __name__ == "__main__":
    main()
